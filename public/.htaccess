Options -MultiViews
RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 1) /?page_id=123  →  /
RewriteCond %{QUERY_STRING} ^page_id=\d+$
RewriteRule ^ / [R=301,L,QSD]

# 2) Serve real files or directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3) /route/ → /route  (for non-dirs)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/$ /$1 [R=301,L]

# 4) If /route.html exists, serve it for /route
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]

# Optional: make sure index files are picked up inside real directories
DirectoryIndex index.html

# Optional: exported 404
ErrorDocument 404 /404.html
