Options -MultiViews
RewriteEngine On
RewriteBase /

# Serve real files or directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# If /route/ is requested but no real dir exists, 301 to /route
# (IMPORTANT: start substitution with "/" to avoid filesystem-looking Location:)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+?)/$ /$1 [R=301,L]

# If /route.html exists, serve it for /route
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]

# Optional: make sure index files are picked up inside real directories
DirectoryIndex index.html

# Optional: exported 404
ErrorDocument 404 /404.html
